{
  "name": "fean-container-manager",
  "displayName": "Container Manager",
  "description": "Gerencie containers, imagens, volumes e redes Docker diretamente no VS Code.",
  "version": "0.1.4",
  "publisher": "fean-developer",
  "repository": {
    "type": "git",
    "url": "https://github.com/fean-developer/docker-manager-vscode.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "docker",
    "containers",
    "devops",
    "portainer"
  ],
  "icon": "resources/icon.png",
  "activationEvents": [
    "onStartupFinished",
    "onView:dockerManager.containers",
    "onView:dockerManager.images",
    "onView:dockerManager.volumes",
    "onView:dockerManager.networks",
    "onCommand:dockerManager.refresh",
    "onCommand:dockerManager.startContainer",
    "onCommand:dockerManager.stopContainer",
    "onCommand:dockerManager.restartContainer",
    "onCommand:dockerManager.removeContainer",
    "onCommand:dockerManager.showContainerLogs",
    "onCommand:dockerManager.execShell",
    "onCommand:dockerManager.inspectContainer",
    "onCommand:dockerManager.removeImage",
    "onCommand:dockerManager.pruneImages",
    "onCommand:dockerManager.removeVolume",
    "onCommand:dockerManager.pruneVolumes",
    "onCommand:dockerManager.openDashboard",
    "onCommand:dockerManager.openContainerList",
    "onCommand:dockerManager.openImageList",
    "onCommand:dockerManager.openVolumeList",
    "onCommand:dockerManager.openNetworkList"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dockerManager",
          "title": "Docker Manager",
          "icon": "resources/docker.svg"
        }
      ]
    },
    "views": {
      "dockerManager": [
        {
          "id": "dockerManager.containers",
          "name": "Containers"
        },
        {
          "id": "dockerManager.images",
          "name": "Imagens"
        },
        {
          "id": "dockerManager.volumes",
          "name": "Volumes"
        },
        {
          "id": "dockerManager.networks",
          "name": "Redes"
        }
      ]
    },
    "commands": [
      {
        "command": "dockerManager.refresh",
        "title": "Atualizar",
        "icon": "$(refresh)",
        "category": "Docker Manager"
      },
      {
        "command": "dockerManager.startContainer",
        "title": "Iniciar Container",
        "icon": "$(play)",
        "category": "Docker Manager"
      },
      {
        "command": "dockerManager.stopContainer",
        "title": "Parar Container",
        "icon": "$(debug-stop)",
        "category": "Docker Manager"
      },
      {
        "command": "dockerManager.restartContainer",
        "title": "Reiniciar Container",
        "icon": "$(debug-restart)",
        "category": "Docker Manager"
      },
      {
        "command": "dockerManager.removeContainer",
        "title": "Remover Container",
        "icon": "$(trash)",
        "category": "Docker Manager"
      },
      {
        "command": "dockerManager.showContainerLogs",
        "title": "Ver Logs",
        "icon": "$(output)",
        "category": "Docker Manager"
      },
      {
        "command": "dockerManager.execShell",
        "title": "Abrir Terminal no Container",
        "icon": "$(terminal)",
        "category": "Docker Manager"
      },
      {
        "command": "dockerManager.inspectContainer",
        "title": "Inspecionar Container",
        "icon": "$(search)",
        "category": "Docker Manager"
      },
      {
        "command": "dockerManager.removeImage",
        "title": "Remover Imagem",
        "icon": "$(trash)",
        "category": "Docker Manager"
      },
      {
        "command": "dockerManager.pruneImages",
        "title": "Remover Imagens Não Utilizadas",
        "icon": "$(clear-all)",
        "category": "Docker Manager"
      },
      {
        "command": "dockerManager.removeVolume",
        "title": "Remover Volume",
        "icon": "$(trash)",
        "category": "Docker Manager"
      },
      {
        "command": "dockerManager.pruneVolumes",
        "title": "Remover Volumes Não Utilizados",
        "icon": "$(clear-all)",
        "category": "Docker Manager"
      },
      {
        "command": "dockerManager.openDashboard",
        "title": "Abrir Dashboard",
        "icon": "$(dashboard)",
        "category": "Docker Manager"
      },
      {
        "command": "dockerManager.openContainerList",
        "title": "Lista de Containers",
        "icon": "$(list-unordered)",
        "category": "Docker Manager"
      },
      {
        "command": "dockerManager.openImageList",
        "title": "Lista de Imagens",
        "icon": "$(package)",
        "category": "Docker Manager"
      },
      {
        "command": "dockerManager.openVolumeList",
        "title": "Lista de Volumes",
        "icon": "$(database)",
        "category": "Docker Manager"
      },
      {
        "command": "dockerManager.openNetworkList",
        "title": "Lista de Redes",
        "icon": "$(plug)",
        "category": "Docker Manager"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "dockerManager.openDashboard",
          "when": "view =~ /^dockerManager\\./",
          "group": "navigation@1"
        },
        {
          "command": "dockerManager.openContainerList",
          "when": "view == dockerManager.containers",
          "group": "navigation@2"
        },
        {
          "command": "dockerManager.openImageList",
          "when": "view == dockerManager.images",
          "group": "navigation@2"
        },
        {
          "command": "dockerManager.openVolumeList",
          "when": "view == dockerManager.volumes",
          "group": "navigation@2"
        },
        {
          "command": "dockerManager.openNetworkList",
          "when": "view == dockerManager.networks",
          "group": "navigation@2"
        },
        {
          "command": "dockerManager.refresh",
          "when": "view =~ /^dockerManager\\./",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "dockerManager.startContainer",
          "when": "view == dockerManager.containers && viewItem == container-stopped",
          "group": "inline@1"
        },
        {
          "command": "dockerManager.stopContainer",
          "when": "view == dockerManager.containers && viewItem == container-running",
          "group": "inline@1"
        },
        {
          "command": "dockerManager.restartContainer",
          "when": "view == dockerManager.containers && viewItem == container-running",
          "group": "inline@2"
        },
        {
          "command": "dockerManager.removeContainer",
          "when": "view == dockerManager.containers && viewItem =~ /^container-/",
          "group": "inline@3"
        },
        {
          "command": "dockerManager.removeImage",
          "when": "view == dockerManager.images && viewItem == image",
          "group": "inline@1"
        },
        {
          "command": "dockerManager.removeVolume",
          "when": "view == dockerManager.volumes && viewItem == volume",
          "group": "inline@1"
        },
        {
          "command": "dockerManager.startContainer",
          "when": "view == dockerManager.containers && viewItem == container-stopped",
          "group": "1_actions@1"
        },
        {
          "command": "dockerManager.stopContainer",
          "when": "view == dockerManager.containers && viewItem == container-running",
          "group": "1_actions@2"
        },
        {
          "command": "dockerManager.restartContainer",
          "when": "view == dockerManager.containers && viewItem =~ /^container-/",
          "group": "1_actions@3"
        },
        {
          "command": "dockerManager.showContainerLogs",
          "when": "view == dockerManager.containers && viewItem =~ /^container-/",
          "group": "2_info@1"
        },
        {
          "command": "dockerManager.execShell",
          "when": "view == dockerManager.containers && viewItem == container-running",
          "group": "2_info@2"
        },
        {
          "command": "dockerManager.inspectContainer",
          "when": "view == dockerManager.containers && viewItem =~ /^container-/",
          "group": "2_info@3"
        },
        {
          "command": "dockerManager.removeContainer",
          "when": "view == dockerManager.containers && viewItem =~ /^container-/",
          "group": "3_destructive@1"
        },
        {
          "command": "dockerManager.removeImage",
          "when": "view == dockerManager.images && viewItem == image",
          "group": "1_actions@1"
        },
        {
          "command": "dockerManager.pruneImages",
          "when": "view == dockerManager.images",
          "group": "2_cleanup@1"
        },
        {
          "command": "dockerManager.removeVolume",
          "when": "view == dockerManager.volumes && viewItem == volume",
          "group": "1_actions@1"
        },
        {
          "command": "dockerManager.pruneVolumes",
          "when": "view == dockerManager.volumes",
          "group": "2_cleanup@1"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run bundle -- --production",
    "vscode:release": "rm -rf out/ vscode-docker-manager-*.vsix && npm run vscode:prepublish && vsce package",
    "compile": "tsc -p ./",
    "bundle": "node esbuild.js",
    "bundle:watch": "node esbuild.js --watch",
    "deploy:local": "npm run bundle && cp out/extension.js ~/.vscode-server/extensions/docker-manager.vscode-docker-manager-0.1.2/out/extension.js && cp out/extension.js.map ~/.vscode-server/extensions/docker-manager.vscode-docker-manager-0.1.2/out/extension.js.map",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/sinon": "^21.0.1",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/test-electron": "^2.3.0",
    "esbuild": "^0.28.0",
    "eslint": "^8.57.0",
    "glob": "^13.0.6",
    "mocha": "^11.3.0",
    "sinon": "^21.1.2",
    "typescript": "^5.3.0"
  },
  "dependencies": {
    "@types/dockerode": "^3.3.0",
    "dockerode": "^4.0.10"
  },
  "overrides": {
    "uuid": ">=14.0.0",
    "serialize-javascript": "7.0.5"
  }
}
